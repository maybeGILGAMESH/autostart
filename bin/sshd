#!/usr/bin/env bash
set -euo pipefail

BASE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
KEY_DIR="$BASE_DIR/generated/sshd_keys"
LOG_FILE="$BASE_DIR/logs/sshd_wrapper.log"
REAL_SSHD="/usr/sbin/sshd"

mkdir -p "$KEY_DIR" "$(dirname "$LOG_FILE")"

run_keygen() {
  local type="$1"
  local path="$2"
  if [[ ! -f "$path" ]]; then
    ssh-keygen -q -t "$type" -N "" -f "$path" >/dev/null
  fi
}

run_keygen rsa "$KEY_DIR/ssh_host_rsa_key"
run_keygen ecdsa "$KEY_DIR/ssh_host_ecdsa_key"
run_keygen ed25519 "$KEY_DIR/ssh_host_ed25519_key"

{
  printf '[%s] sshd wrapper args:' "$(date --iso-8601=seconds)"
  for arg in "$@"; do
    printf ' %q' "$arg"
  done
  printf '\n'
} >>"$LOG_FILE"

exec "$REAL_SSHD" \
  -h "$KEY_DIR/ssh_host_rsa_key" \
  -h "$KEY_DIR/ssh_host_ecdsa_key" \
  -h "$KEY_DIR/ssh_host_ed25519_key" \
  -o "PidFile=$BASE_DIR/generated/sshd.pid" \
  -o "UsePAM=no" \
  -o "PrintMotd=no" \
  -o "X11Forwarding=no" \
  "$@"
