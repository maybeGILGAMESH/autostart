[Unit]
Description=Daily health check for autostart stack
After=network-online.target autostart-vnc-keepalive.service autostart-test-bot.service autostart-tuna-backup.service
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/home/user/autostart
ExecStart=/home/user/autostart/health_check.sh

[Install]
WantedBy=multi-user.target
