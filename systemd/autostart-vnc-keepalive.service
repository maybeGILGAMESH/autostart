[Unit]
Description=Autostart VNC keepalive
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=user
Group=user
WorkingDirectory=/home/user/autostart
Environment=HOME=/home/user
ExecStart=/home/user/autostart/vnc_keepalive.sh
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
