[Unit]
Description=Autostart tuna tunnel backup service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=user
Group=user
WorkingDirectory=/home/user/autostart
Environment=HOME=/home/user
ExecStart=/home/user/autostart/tuna_headless.sh
Restart=always
RestartSec=15

[Install]
WantedBy=multi-user.target
